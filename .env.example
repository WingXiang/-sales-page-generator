# GitHub Pages 部署基礎路徑 (例如: /sales-page-generator/)
# 若設定為 ./，則會使用相對路徑，適用於大多數部署環境
VITE_BASE_PATH=./

# AI 文案生成的 serverless 代理端點
# 不設定時預設為同源的 /api/generate（前後端一起部署在 Vercel 時適用）。
# 若前端留在 GitHub Pages、代理另外部署在 Vercel，請填完整網址，例如：
# VITE_AI_PROXY_URL=https://your-proxy.vercel.app/api/generate
VITE_AI_PROXY_URL=

# ↓↓↓ 以下變數設定在「Vercel 後端」，請勿放進前端 bundle，亦勿提交真實值 ↓↓↓
# ANTHROPIC_API_KEY=你的_Anthropic_API_Key   # sk-ant-...，到 console.anthropic.com 取得
# ANTHROPIC_MODEL=claude-opus-4-8            # 選填；省成本可改 claude-sonnet-4-6 或 claude-haiku-4-5
# ALLOWED_ORIGIN=https://你的前端網域         # 選填，限制可呼叫代理的來源
